<?xml version="1.0" encoding="utf-8"?>
<!--
    The main layout uses a vertical LinearLayout.
    We use android:layout_weight="1" on a View element to push the bottom
    button bar (Next/Back) to the bottom of the screen.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".SignUpActivity">

    <!-- 1. Title: "Sign Up" in bold at the top -->
    <TextView
        android:id="@+id/tv_sign_up_title"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="32dp"
        android:gravity="center_horizontal"
        android:text="Sign Up"
        android:textSize="32sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText" />

    <!-- 2. Input Field: Name -->
    <EditText
        android:id="@+id/et_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="@string/full_name"
        android:inputType="textPersonName|textCapWords"
        android:padding="12dp" />

    <!-- 2. Input Field: CNIC (using number input for simplicity) -->
    <EditText
        android:id="@+id/et_cnic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="@string/cnic"
        android:inputType="number"
        android:maxLength="15"
        android:padding="12dp" />

    <!-- 2. Input Field: Registration Number -->
    <EditText
        android:id="@+id/et_reg_no"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="@string/registration_number"
        android:inputType="textCapCharacters"
        android:padding="12dp" />

    <!-- 2. Input Field: Email Address -->
    <EditText
        android:id="@+id/et_email"
        android:layout_width="match_parent"
        android:layout_height="37dp"
        android:layout_marginBottom="24dp"
        android:hint="@string/email_address"
        android:inputType="textEmailAddress"
        android:padding="12dp" />

    <!-- 3. Cancel and Submit Buttons (Horizontal Layout) -->
    <!-- Placed just below the email address element -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <!-- Cancel Button (Left Side) -->
        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/cancel"
            android:backgroundTint="#4CAF50"
            android:layout_marginEnd="8dp" />

        <!-- Submit Button (Right Side) -->
        <Button
            android:id="@+id/btn_submit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/submit"
            android:backgroundTint="#4CAF50"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Spacer View: Pushes the final buttons to the bottom using layout_weight="1" -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- 4. Next and Back Buttons (Horizontal Layout at the end of the page) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Back Button (Left Side) -->
        <Button
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/back"
            android:backgroundTint="#4CAF50"

            android:layout_marginEnd="8dp" />

        <!-- Next Button (Right Side) -->
        <Button
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#4CAF50"

            android:text="@string/next"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
